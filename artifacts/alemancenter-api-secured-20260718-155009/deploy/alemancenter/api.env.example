# =============================================================================
# Backend Production Environment — api.alemancenter.com
# =============================================================================
APP_ENV=production
APP_HOST=127.0.0.1
APP_PORT=8082
APP_URL=https://api.alemancenter.com
FRONTEND_URL=https://alemancenter.com

# CORS / proxy
CORS_ALLOWED_ORIGINS=https://alemancenter.com,https://www.alemancenter.com
TRUSTED_PROXIES=127.0.0.1,::1,152.53.208.71,2a0a:4cc0:2000:c6b0::10
SSR_TRUSTED_IPS=127.0.0.1,::1

# Must match frontend FRONTEND_API_KEY/NEXT_PUBLIC_FRONTEND_API_KEY
FRONTEND_API_KEY=REPLACE_WITH_STRONG_RANDOM_KEY
JWT_SECRET=REPLACE_WITH_AT_LEAST_32_CHARS

# Protects /api/ping, /api/health, and /metrics for remote monitoring.
# Direct localhost checks are allowed without this header.
# Remote monitors must send: X-Internal-Monitor-Key: this_value
INTERNAL_MONITOR_KEY=REPLACE_WITH_STRONG_RANDOM_KEY

# Databases — fill real values
DB_HOST_JO=127.0.0.1
DB_PORT_JO=3306
DB_NAME_JO=REPLACE_DB
DB_USER_JO=REPLACE_USER
DB_PASSWORD_JO=REPLACE_PASSWORD

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Mail — fill real values
MAIL_HOST=localhost
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@alemancenter.com
MAIL_FROM_NAME=Alemancenter

# ──────────────────────────────────────────────
# AdSense — canonical publisher ID
# ──────────────────────────────────────────────
# When set, this value overrides the per-country DB value for adsense_client.
# This guarantees every page on the domain returns the SAME ca-pub-* ID,
# which is required by Google AdSense policy (one account per domain).
ADSENSE_CLIENT=ca-pub-2187451543840210

# ──────────────────────────────────────────────
# reCAPTCHA (contact form)
# ──────────────────────────────────────────────
# Set this to enable reCAPTCHA on the contact form.
# Without it the form works but is unprotected against bots.
# Get keys at https://www.google.com/recaptcha/admin
# RECAPTCHA_SITE_KEY=YOUR_SITE_KEY
# RECAPTCHA_SECRET_KEY=YOUR_SECRET_KEY

# ──────────────────────────────────────────────
# CookieYes (GDPR Consent Banner)
# ──────────────────────────────────────────────
# Set the frontend env NEXT_PUBLIC_COOKIEYES_CLIENT_ID to enable the consent banner.
# Required for Google Consent Mode v2 / AdSense compliance.
# https://www.cookieyes.com/

# Chatbot V4 AI Guarded RAG
CHATBOT_AI_ENABLED=true
CHATBOT_AI_PROVIDER=together
CHATBOT_AI_MODEL=openai/gpt-oss-20b
CHATBOT_AI_MODELS=openai/gpt-oss-20b,meta-llama/Llama-3.3-70B-Instruct-Turbo,Qwen/Qwen3-235B-A22B-Instruct-2507-tput,zai-org/GLM-5.1,google/gemma-3n-E4B-it
CHATBOT_AI_MAX_TOKENS=520
CHATBOT_AI_GUEST_LIMIT_10M=5
CHATBOT_AI_USER_LIMIT_10M=15
CHATBOT_AI_DAILY_LIMIT=1000
